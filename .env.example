# Copy to .env and source before running anything.
#   cp .env.example .env
#   set -a; source .env; set +a

# Project-local Hugging Face cache (do NOT use ~/.cache/huggingface).
HF_HOME=${HF_HOME:-$PWD/.cache/huggingface}

# Tokenizer parallelism warning silencer (safe to leave on).
TOKENIZERS_PARALLELISM=false

# Default device list for the sharded launcher (overrides configs/hardware.yaml).
# CUDA_DEVICES=4,5,6,7

# Optional: enable wandb logging (off by default).
# WANDB_PROJECT=slm-universe-learning
# WANDB_MODE=offline
